# CS-REGISTRY — Contextus Registry (trust anchor)
# See specs/CS-REGISTRY.md for formal specification.
# Lines starting with # are comments. Parsers MUST skip them.

# --- header fields ---
{"kind":"header","field":"Type","level":"MUST","values":["CONTEXT","TODO","TASK","SPEC","DESIGN","KNOWLEDGE","DRAFT","CONSTITUTION","PLAN","MINUTES","WORKLOG","README","AGENTS","RULE"],"format":"enum","description":"Document type identifier. YAML frontmatter with Type: makes a file CS-MD","registered_by":"L0/contextus","reference":"Dublin Core type, OpenGraph og:type, RFC Category"}
{"kind":"header","field":"Updated","level":"MUST","format":"ISO 8601 (YYYY-MM-DD or YYYY-MM-DDTHH:MM)","description":"Last modification timestamp","registered_by":"L0/contextus","reference":"Schema.org dateModified, HTTP Last-Modified"}
{"kind":"header","field":"Version","level":"MAY","format":"SemVer (X.Y.Z)","description":"Document version. Major = breaking section change, Minor = section added, Patch = content update","registered_by":"L0/contextus","reference":"Schema.org version, SemVer 2.0"}
{"kind":"header","field":"Provenance","level":"MAY","format":"repo@branch:short-hash or chain (a@b:h-->c@d:h)","description":"Origin and lineage. Hash = identifier (globally unique via SHA). repo@branch = locator (human context)","registered_by":"L0/contextus","reference":"SPDX VCS locator, purl, Dublin Core source"}
{"kind":"header","field":"Status","level":"MAY","values":["draft","discussion","in_progress","confirmed","active","stable","archived"],"format":"enum","description":"Document lifecycle state","registered_by":"L0/contextus","reference":"Schema.org CreativeWorkStatus, RFC Status, GitHub state"}
{"kind":"header","field":"Tags","level":"MAY","format":"comma-separated","description":"Classification and search keywords","registered_by":"L0/contextus","reference":"Dublin Core subject, Schema.org keywords"}
{"kind":"header","field":"Context","level":"MAY","format":"reference","description":"Link to discussion origin (e.g., MINUTES entry)","registered_by":"L0/contextus"}
{"kind":"header","field":"Description","level":"MAY","format":"single line","description":"Short summary for indexing","registered_by":"L0/contextus","reference":"Dublin Core description"}

# --- document types (non-Structured-Flow) ---
{"kind":"type","field":"README","level":"MAY","description":"Project README. Provenance tracks which version/origin","registered_by":"L0/contextus"}
{"kind":"type","field":"AGENTS","level":"MAY","description":"AAIF agent instructions. Provenance tracks L0 version","registered_by":"L0/contextus","reference":"AAIF AGENTS.md"}
{"kind":"type","field":"RULE","level":"MAY","description":"L0/L2/L3 rule file. Provenance replaces L-prefix naming","registered_by":"L0/contextus"}

# --- sections ---
{"kind":"section","field":"Task","level":"MUST","types":["CONTEXT"],"description":"Current or next execution unit","registered_by":"L0/contextus"}
{"kind":"section","field":"Context","level":"MUST","types":["CONTEXT","TASK"],"description":"Relevant context for the task","registered_by":"L0/contextus"}
{"kind":"section","field":"Goal","level":"MUST","types":["TASK"],"description":"What this task should accomplish","registered_by":"L0/contextus"}
{"kind":"section","field":"Blockers","level":"SHOULD","types":["CONTEXT"],"description":"Blocking issues preventing progress","registered_by":"L0/contextus"}
{"kind":"section","field":"Completed","level":"SHOULD","types":["CONTEXT"],"description":"Work completed in current/recent session","registered_by":"L0/contextus"}
{"kind":"section","field":"Decisions","level":"MAY","types":["CONTEXT"],"description":"Key decisions made and rationale","registered_by":"L0/contextus"}
{"kind":"section","field":"References","level":"MUST","types":["CONSTITUTION","SPEC","DESIGN"],"description":"Related documents (normative). Design roots must be traceable","registered_by":"L0/contextus","reference":"RFC References section"}
{"kind":"section","field":"References","level":"SHOULD","types":["TASK","KNOWLEDGE"],"description":"Related documents. Mature entries should cite their sources","registered_by":"L0/contextus"}
{"kind":"section","field":"References","level":"MAY","types":["CONTEXT","DRAFT","PLAN","TODO"],"description":"Related documents (optional for ephemeral/exploratory types)","registered_by":"L0/contextus"}
{"kind":"section","field":"Changed Files","level":"MAY","types":["CONTEXT"],"description":"List of files modified","registered_by":"L0/contextus"}

{"kind":"section","field":"Acceptance Criteria","level":"SHOULD","types":["TASK"],"description":"Conditions for task completion","registered_by":"L0/contextus"}
{"kind":"section","field":"Problem","level":"SHOULD","types":["DRAFT"],"description":"Problem statement being explored","registered_by":"L0/contextus"}
{"kind":"section","field":"Open Questions","level":"SHOULD","types":["DRAFT"],"description":"Unresolved questions under discussion","registered_by":"L0/contextus"}
{"kind":"section","field":"Inherited Principles","level":"MUST","types":["CONSTITUTION"],"description":"Principles inherited from lower layers","registered_by":"L0/contextus"}

# --- markers ---
{"kind":"marker","field":"[NEEDS CLARIFICATION]","level":"MAY","types":["SPEC","DESIGN","DRAFT"],"description":"Unresolved ambiguity placeholder. Must be resolved before confirmation","registered_by":"L0/contextus","reference":"GitHub Spec Kit clarify pattern"}
{"kind":"marker","field":"[STABLE]","level":"MAY","types":["KNOWLEDGE"],"description":"Stable entry safe to archive. Will not change","registered_by":"L0/contextus"}
{"kind":"marker","field":"[ACTIVE]","level":"MAY","types":["KNOWLEDGE","TODO"],"description":"In-progress entry. Keep in Layer 1 (index injection)","registered_by":"L0/contextus"}
{"kind":"marker","field":"[DEPRECATED]","level":"MAY","types":["*"],"description":"Superseded entry. Archive candidate. Must indicate replacement","registered_by":"L0/contextus"}
{"kind":"marker","field":"[RECALL-REQUIRED]","level":"MAY","types":["KNOWLEDGE"],"description":"Must be Read before related design decisions (enforcement trigger)","registered_by":"L0/contextus"}
{"kind":"marker","field":"[MUST]","level":"MAY","types":["SPEC","CONSTITUTION"],"description":"Mandatory requirement (RFC 2119)","registered_by":"L0/contextus","reference":"RFC 2119"}
{"kind":"marker","field":"[MAY]","level":"MAY","types":["SPEC"],"description":"Optional requirement (RFC 2119)","registered_by":"L0/contextus","reference":"RFC 2119"}

# --- provenance markers ---
{"kind":"marker","field":"[SPECIFIED]","level":"MAY","types":["TODO","TASK"],"description":"Derived from a formal SPEC. Must reference the source SPEC","registered_by":"L0/contextus"}
{"kind":"marker","field":"[DIRECTED]","level":"MAY","types":["TODO","TASK"],"description":"Directly instructed by human. Should reference MINUTES or date","registered_by":"L0/contextus"}
{"kind":"marker","field":"[DISCOVERED]","level":"MAY","types":["TODO","TASK"],"description":"Found during work. Should reference KNOWLEDGE or discovery context","registered_by":"L0/contextus"}

# --- vocabulary discovery ---
{"kind":"meta","field":"Registry","level":"MAY","format":"path to registry.jsonl","description":"Self-reference for external agents without rules injection. Well-known path: contextus L0 registry.jsonl","registered_by":"L0/contextus"}
